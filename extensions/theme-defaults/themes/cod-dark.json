	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "foreground": "#6e6e73" }
		},
		{
			"scope": ["constant", "entity.name.constant"],
			"settings": { "foreground": "#007aff" }
		},
		{
			"scope": "entity.name.function",
			"settings": { "foreground": "#00BCA2" }
		},
		{
			"scope": ["keyword", "storage", "storage.type"],
			"settings": { "foreground": "#ff3b30" }
		},
		{
			"scope": ["string", "string punctuation.section.embedded source"],
			"settings": { "foreground": "#30d158" }
		},
		{
			"scope": "support",
			"settings": { "foreground": "#007aff" }
		},
		{
			"scope": "variable",
			"settings": { "foreground": "#ff9f0a" }
		},
		{
			"scope": ["entity.name.tag", "support.class.component"],
			"settings": { "foreground": "#00BCA2" }
		},
		{
			"scope": ["markup.heading", "markup.heading entity.name"],
			"settings": { "foreground": "#fdfcfc", "fontStyle": "bold" }
		},
		{
			"scope": "markup.inline.raw",
			"settings": { "foreground": "#9a9898" }
		},
		{
			"scope": "token.info-token",
			"settings": { "foreground": "#007aff" }
		},
		{
			"scope": "token.warn-token",
			"settings": { "foreground": "#ff9f0a" }
		},
		{
			"scope": "token.error-token",
			"settings": { "foreground": "#ff3b30" }
		},
		{
			"scope": "token.debug-token",
			"settings": { "foreground": "#bf5af2" }
		}
	],
	"semanticHighlighting": true
}
