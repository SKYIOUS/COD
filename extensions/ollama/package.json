{
  "name": "ollama",
  "displayName": "Ollama",
  "description": "Local AI chat powered by Ollama",
  "version": "1.0.0",
  "publisher": "cod",
  "license": "MIT",
  "engines": {
    "vscode": "^1.127.0"
  },
  "main": "./out/extension",
  "browser": "./out/browser/extension",
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onLanguageModelChat:ollama",
    "onCommand:ollama.selectModel",
    "onCommand:ollama.checkStatus"
  ],
  "enabledApiProposals": [
    "chatProvider"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "ollama.selectModel",
        "title": "Ollama: Select Model"
      },
      {
        "command": "ollama.checkStatus",
        "title": "Ollama: Check Connection Status"
      }
    ],
    "configuration": {
      "title": "Ollama",
      "properties": {
        "ollama.url": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "ollama.model": {
          "type": "string",
          "default": "llama3.2",
          "description": "Default model to use"
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "ollama",
        "displayName": "Ollama",
        "configuration": {
          "properties": {
            "url": {
              "type": "string",
              "default": "http://localhost:11434",
              "description": "Ollama server URL"
            },
            "model": {
              "type": "string",
              "default": "llama3.2",
              "description": "Default model to use"
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "compile": "gulp compile-extension:ollama",
    "watch": "gulp watch-extension:ollama",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SKYIOUS/COD"
  }
}
